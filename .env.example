# Mapbox (geospatial visualization)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Pinata (IPFS pinning)
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret

# Kafka (sensor data streaming)
KAFKA_BOOTSTRAP=localhost:9092

# Cardano (Blockfrost API for Pre-Prod)
BLOCKFROST_PROJECT_ID=preprodYourProjectId

# EVM (Base Sepolia RPC)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Contract deployment keys (use test keys only)
AI_VALIDATOR_KEY=0x_your_test_private_key
ADMIN_KEY=0x_your_test_private_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Auth0 Next.js SDK (@auth0/nextjs-auth0) — Regular Web Application
# In Auth0 Dashboard → Applications → your app:
#   Allowed Callback URLs: http://localhost:3000/auth/callback
#   Allowed Logout URLs: http://localhost:3000
# Token Endpoint Authentication Method: Client Secret Post (matches SDK default)
APP_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# openssl rand -hex 32
AUTH0_SECRET=
# Optional API audience (resource identifier) for access tokens / Magic IDP alignment
AUTH0_AUDIENCE=

# Genesis NFT (EVM) — used by web mint + card/custodial flow
NEXT_PUBLIC_GENESIS_CONTRACT_ADDRESS=0x_your_genesis_validator

# Card checkout (Stripe) + custodial wallet — default `magic` (Magic Email OTP → embedded wallet).
# Use `server` for legacy server-generated keys + transfer link only.
MALAMA_CARD_CUSTODY=magic
NEXT_PUBLIC_MAGIC_API_KEY=pk_live_or_test_your_magic_publishable_key
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Magic Secret API key (server) — validates DID tokens from /launch; same key family as Magic Express if applicable
MAGIC_SECRET_KEY=

# Card checkout (Stripe) + custodial Base wallet
# Publishable key (safe for browser; optional for Checkout redirect-only flow)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
# Webhook URL: POST https://<your-domain>/api/webhooks/stripe
# Secret key (server-only). apps/web prefers NEXT_PRIVATE_STRIPE_KEY; STRIPE_SECRET_KEY also works.
NEXT_PRIVATE_STRIPE_KEY=sk_test_your_secret_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_signing_secret
# AES key for encrypting custodial private keys at rest (min 16 chars; use 32+ random in prod)
CUSTODIAL_ENCRYPTION_KEY=change_me_to_a_long_random_secret
# Signed httpOnly cookie for dashboard email sign-in (falls back to CUSTODIAL_ENCRYPTION_KEY if unset)
EMAIL_SESSION_SECRET=change_me_to_a_long_random_secret
# Contract owner key — must match GenesisValidator owner (calls adminSecureNode for card purchases)
GENESIS_ADMIN_PRIVATE_KEY=0x_your_owner_private_key

# Magic Express API (fiat / non-custodial-server-wallet users — OIDC + TEE wallets)
# Server-only; never expose to the browser.
MAGIC_SECRET_KEY=your_magic_secret_key
# After POST /api/admin/magic/identity-provider, save the returned id:
MAGIC_OIDC_PROVIDER_ID=
# Express wallet API: chain hint (e.g. ETH, BASE). See Magic Express docs.
MAGIC_EXPRESS_CHAIN=ETH
# Optional defaults for that POST (or pass issuer / audience / jwks_uri in JSON body)
MAGIC_IDP_ISSUER=https://your-auth-provider.com
MAGIC_IDP_AUDIENCE=your-app-audience
MAGIC_IDP_JWKS_URI=https://your-auth-provider.com/.well-known/jwks.json
# Protects admin Magic routes (x-malama-ops-key or Authorization: Bearer)
MALAMA_OPS_KEY=change_me_long_random_secret
