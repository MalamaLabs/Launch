# Preferred: copy to `.env.local` in this directory (apps/web).
# Also supported: set the same variables in the monorepo root `.env.local` — Next.js merges them at startup.
# Restart `npm run dev` after changes.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Magic (https://dashboard.magic.link) — same app as your publishable key
NEXT_PUBLIC_MAGIC_API_KEY=pk_live_OR_pk_test_your_key
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Server-only: Magic Secret API key (Dashboard → API Keys) — validates DID on /api/custodial/magic-claim
MAGIC_SECRET_KEY=

# Card custody: magic (default) = Launch app + Email OTP; server = legacy encrypted custodial key
MALAMA_CARD_CUSTODY=magic
