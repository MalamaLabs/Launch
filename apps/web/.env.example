# Preferred: copy to `.env.local` in this directory (apps/web).
# Also supported: set the same variables in the monorepo root `.env.local` — Next.js merges them at startup.
# Restart `npm run dev` after changes.

# ─── Core ─────────────────────────────────────────────────────────────────
# Public URL the frontend is served from (used for NFT image/metadata URIs).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── dagwelldev-api backend ───────────────────────────────────────────────
# All hex sale state (purchases, Cardano mirror, Stripe) lives on the Fastify
# backend. Point this at the local instance during development, or the
# production host (default below).
NEXT_PUBLIC_DAGWELLDEV_API_BASE=https://api.dagwelldev.com
# NEXT_PUBLIC_DAGWELLDEV_API_BASE=http://localhost:3050

# ─── On-chain addresses (optional fallbacks) ──────────────────────────────
# These are only used if /hexes/:hexId/purchase-intent returns without a
# contract/usdcAddress. In normal operation the backend supplies them.
NEXT_PUBLIC_GENESIS_CONTRACT_ADDRESS=
NEXT_PUBLIC_MOCK_USDC_ADDRESS=

# ─── Pre-minted reserves display ──────────────────────────────────────────
# Shown on the detail page for the 5 Malama-Wallet-custody hexes.
NEXT_PUBLIC_MALAMA_GENESIS_WALLET=

# ─── Magic.link ───────────────────────────────────────────────────────────
# Required for the Card (Magic Wallet) purchase lane.
#   NEXT_PUBLIC_MAGIC_API_KEY  — publishable key; initialises the browser SDK
#                                (MagicProvider) and shows the Email OTP UI.
#   MAGIC_SECRET_KEY           — secret key; used SERVER-SIDE in
#                                src/lib/fulfill-card-purchase.ts to verify the
#                                buyer's DID token before minting.
# Both keys come from dashboard.magic.link → your app → Settings → API Keys.
# The domain serving this app (e.g. dev.dagwelldev.com, localhost:3002, and the
# production domain) must be added to Allowed Domains in the same dashboard.
NEXT_PUBLIC_MAGIC_API_KEY=pk_live_XXXXXXXXXXXXXXXX
MAGIC_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXX

# ─── Base network RPC (optional override) ────────────────────────────────
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ─── Legacy (no longer required — kept for reference) ─────────────────────
# The following used to be wired into Next.js API routes that have been
# superseded by dagwelldev-api. Leave blank unless you are running the
# legacy custody flow on the old Next.js routes.
#
# MALAMA_CARD_CUSTODY=magic
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# BLOCKFROST_API_KEY=
# TREASURY_MNEMONIC=
